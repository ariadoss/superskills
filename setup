#!/usr/bin/env bash
set -e
umask 077

# ── Flags ──────────────────────────────────────────────────────────────────────
QUIET=0
NO_KNOWLEDGE=0
EXTEND_FROM=""

while [ $# -gt 0 ]; do
  case "$1" in
    -q|--quiet)        QUIET=1; shift ;;
    --no-knowledge)    NO_KNOWLEDGE=1; shift ;;
    --extend-from)     EXTEND_FROM="$2"; shift 2 ;;
    --extend-from=*)   EXTEND_FROM="${1#--extend-from=}"; shift ;;
    *) shift ;;
  esac
done

log() { [ "$QUIET" -eq 0 ] && echo "$@" || true; }

# ── Banner ─────────────────────────────────────────────────────────────────────
log ""
log "  superskills setup  (v$(cat "$(dirname "$0")/VERSION" 2>/dev/null | tr -d '[:space:]'))"
log "  ──────────────────────────────"
log ""

# ── Directories ────────────────────────────────────────────────────────────────
SOURCE_DIR="$(cd "$(dirname "$0")" && pwd -P)"
SKILLS_SRC_DIR="$SOURCE_DIR/skills"
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
OPENCODE_SKILLS_DIR="$HOME/.config/opencode/skills"
CONFIG_DIR="$HOME/.superskills"
KB_CONF="$CONFIG_DIR/knowledge.conf"

mkdir -p "$CONFIG_DIR"

# ── Knowledge base configuration ──────────────────────────────────────────────
if [ "$NO_KNOWLEDGE" -eq 0 ]; then
  KB_DIR="$CONFIG_DIR/knowledge"
  mkdir -p "$KB_DIR"

  # If no knowledge.conf exists and we're interactive, prompt for repos
  if [ ! -f "$KB_CONF" ] && [ -t 0 ] && [ "$QUIET" -eq 0 ]; then
    log "  Knowledge Base Setup"
    log "  ────────────────────"
    log "  You can connect git repos as knowledge bases that /kb-advisor"
    log "  and /content-writer will search and reference."
    log ""
    log "  Format: name, git URL (or 'done' to finish, 'skip' to skip)"
    log ""

    while true; do
      printf "  KB name (or done/skip): "
      read -r kb_name </dev/tty 2>/dev/null || break
      [ -z "$kb_name" ] && continue
      [ "$kb_name" = "done" ] && break
      [ "$kb_name" = "skip" ] && break

      printf "  Git URL for '$kb_name': "
      read -r kb_url </dev/tty 2>/dev/null || break
      [ -z "$kb_url" ] && continue

      printf "  Description (optional): "
      read -r kb_desc </dev/tty 2>/dev/null || kb_desc=""
      [ -z "$kb_desc" ] && kb_desc="Knowledge base: $kb_name"

      echo "$kb_name|~/.superskills/knowledge/$kb_name|$kb_desc|$kb_url" >> "$KB_CONF"
      log "  [added] $kb_name"
      log ""
    done
    log ""
  elif [ ! -f "$KB_CONF" ]; then
    # Non-interactive — create empty config
    touch "$KB_CONF"
  fi

  # Clone any knowledge repos that aren't present
  if [ -f "$KB_CONF" ] && [ -s "$KB_CONF" ]; then
    log "  Checking knowledge bases..."
    while IFS='|' read -r name path desc url; do
      [ -z "$name" ] && continue
      [[ "$name" = \#* ]] && continue
      resolved="${path/#\~/$HOME}"
      if [ -d "$resolved/.git" ]; then
        log "  [ok] $name already cloned"
      elif [ -n "$url" ]; then
        log "  [clone] $name"
        git clone --quiet "$url" "$resolved" 2>/dev/null || {
          log "  [warn] Failed to clone $name — check access to $url"
          continue
        }
        log "  [ok] $name cloned"
      else
        log "  [skip] $name — no URL configured"
      fi
    done < "$KB_CONF"
    log ""
  fi
fi

# ── Repomap tool ──────────────────────────────────────────────────────────────
REPOMAP_DIR="$HOME/claude-repomap-command"
if [ -d "$REPOMAP_DIR/.git" ]; then
  log "  [ok] repomap tool already installed"
else
  log "  [clone] repomap tool"
  git clone --quiet https://github.com/ariadoss/repomap.git "$REPOMAP_DIR" 2>/dev/null || {
    log "  [warn] Failed to clone repomap tool"
  }
  [ -d "$REPOMAP_DIR/.git" ] && log "  [ok] repomap tool installed"
fi
log ""

# ── gstack (Garry Tan) ────────────────────────────────────────────────────────
GSTACK_DIR="$HOME/.claude/skills/gstack"
GSTACK_VENDOR_DIR="$SOURCE_DIR/vendor/gstack"

if [ -d "$GSTACK_DIR" ] && [ -f "$GSTACK_DIR/VERSION" ]; then
  log "  [ok] gstack already installed ($(cat "$GSTACK_DIR/VERSION" 2>/dev/null))"
else
  log "  [install] gstack (Garry Tan) — virtual engineering team skills"

  # Ensure bun is installed (required by gstack's browser tool)
  if ! command -v bun >/dev/null 2>&1; then
    log "  [install] bun (required by gstack)..."
    curl -fsSL https://bun.sh/install | bash >/dev/null 2>&1 || {
      log "  [warn] bun install failed — gstack browse tool may not work"
      log "         Install manually: curl -fsSL https://bun.sh/install | bash"
    }
    # Reload PATH to pick up bun
    export PATH="$HOME/.bun/bin:$PATH"
  fi

  if git clone --single-branch --depth 1 --quiet \
       https://github.com/garrytan/gstack.git "$GSTACK_DIR" 2>/dev/null; then
    log "  [ok] gstack cloned"
    (cd "$GSTACK_DIR" && ./setup -q 2>/dev/null) || {
      log "  [warn] gstack setup failed — skills may need manual activation"
    }
    log "  [ok] gstack installed ($(cat "$GSTACK_DIR/VERSION" 2>/dev/null))"
  else
    log "  [warn] gstack clone failed — using vendor copy"
    if [ -d "$GSTACK_VENDOR_DIR" ]; then
      cp -r "$GSTACK_VENDOR_DIR" "$GSTACK_DIR"
      (cd "$GSTACK_DIR" && ./setup -q 2>/dev/null) || true
      log "  [ok] gstack installed from vendor copy"
    else
      log "  [error] vendor copy not found — gstack not installed"
      log "          Manual install: git clone https://github.com/garrytan/gstack.git ~/.claude/skills/gstack && cd ~/.claude/skills/gstack && ./setup"
    fi
  fi
fi
log ""

# ── Dependency checks ─────────────────────────────────────────────────────────
if command -v clearwing >/dev/null 2>&1; then
  log "  [ok] clearwing found"
else
  log "  [optional] clearwing not found — needed for /pentest"
  log "             Install: uv tool install clearwing && clearwing setup"
fi

if command -v ffuf >/dev/null 2>&1; then
  log "  [ok] ffuf found"
else
  log "  [optional] ffuf not found — needed for /fuzz"
  log "             Install: brew install ffuf"
fi

log ""

# ── Link skills into Claude Code ──────────────────────────────────────────────
log "  Linking skills (Claude Code)..."
LINKED=()

link_skill_claude() {
  local skill_md="$1"
  local fallback_name="$2"

  local skill_dir
  skill_dir="$(dirname "$skill_md")"
  local skill_name
  skill_name=$(grep -m1 '^name:' "$skill_md" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]')
  [ -z "$skill_name" ] && skill_name="$fallback_name"
  [ -z "$skill_name" ] && return

  local target="$CLAUDE_SKILLS_DIR/$skill_name"
  mkdir -p "$target"
  [ -L "$target/SKILL.md" ] && rm "$target/SKILL.md"
  ln -snf "$skill_md" "$target/SKILL.md"

  for extra in "$skill_dir"/*; do
    local extra_name
    extra_name="$(basename "$extra")"
    [ "$extra_name" = "SKILL.md" ] && continue
    [ -L "$target/$extra_name" ] && rm "$target/$extra_name"
    ln -snf "$extra" "$target/$extra_name"
  done

  LINKED+=("$skill_name")
}

# Marketing skills (processed first; design and superskills override any name conflicts)
MARKETING_SRC_DIR="$SOURCE_DIR/marketing-skills"
if [ -d "$MARKETING_SRC_DIR" ]; then
  while IFS= read -r skill_md; do
    skill_dir="$(dirname "$skill_md")"
    rel_path="${skill_dir#$MARKETING_SRC_DIR/}"
    fallback_name=$(echo "$rel_path" | tr '/' '-')
    link_skill_claude "$skill_md" "$fallback_name"
  done < <(find "$MARKETING_SRC_DIR" -name "SKILL.md" -type f | sort)
fi

# Design skills (override any marketing-skills name conflicts)
DESIGN_SRC_DIR="$SOURCE_DIR/design-skills"
if [ -d "$DESIGN_SRC_DIR" ]; then
  for skill_md in "$DESIGN_SRC_DIR"/*/SKILL.md; do
    [ -f "$skill_md" ] || continue
    skill_dir="$(dirname "$skill_md")"
    dir_name="$(basename "$skill_dir")"
    [ "$dir_name" = "node_modules" ] && continue
    link_skill_claude "$skill_md" "$dir_name"
  done
fi

# Superskills (override any design/marketing-skills name conflicts)
for skill_md in "$SKILLS_SRC_DIR"/*/SKILL.md; do
  [ -f "$skill_md" ] || continue
  skill_dir="$(dirname "$skill_md")"
  dir_name="$(basename "$skill_dir")"
  [ "$dir_name" = "node_modules" ] && continue
  link_skill_claude "$skill_md" "$dir_name"
done

log "  linked: ${#LINKED[@]} skills"
log ""

# ── Link skills into OpenCode ─────────────────────────────────────────────────
log "  Linking skills (OpenCode)..."
mkdir -p "$OPENCODE_SKILLS_DIR"

link_skill_opencode() {
  local skill_md="$1"
  local fallback_name="$2"

  local skill_name
  skill_name=$(grep -m1 '^name:' "$skill_md" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]')
  [ -z "$skill_name" ] && skill_name="$fallback_name"
  [ -z "$skill_name" ] && return

  local target="$OPENCODE_SKILLS_DIR/superskills-$skill_name"
  mkdir -p "$target"
  [ -L "$target/SKILL.md" ] && rm "$target/SKILL.md"
  ln -snf "$skill_md" "$target/SKILL.md"
}

if [ -d "$MARKETING_SRC_DIR" ]; then
  while IFS= read -r skill_md; do
    skill_dir="$(dirname "$skill_md")"
    rel_path="${skill_dir#$MARKETING_SRC_DIR/}"
    fallback_name=$(echo "$rel_path" | tr '/' '-')
    link_skill_opencode "$skill_md" "$fallback_name"
  done < <(find "$MARKETING_SRC_DIR" -name "SKILL.md" -type f | sort)
fi

if [ -d "$DESIGN_SRC_DIR" ]; then
  for skill_md in "$DESIGN_SRC_DIR"/*/SKILL.md; do
    [ -f "$skill_md" ] || continue
    skill_dir="$(dirname "$skill_md")"
    dir_name="$(basename "$skill_dir")"
    [ "$dir_name" = "node_modules" ] && continue
    link_skill_opencode "$skill_md" "$dir_name"
  done
fi

for skill_md in "$SKILLS_SRC_DIR"/*/SKILL.md; do
  [ -f "$skill_md" ] || continue
  skill_dir="$(dirname "$skill_md")"
  dir_name="$(basename "$skill_dir")"
  [ "$dir_name" = "node_modules" ] && continue
  link_skill_opencode "$skill_md" "$dir_name"
done

log "  done"
log ""

# ── Summary ────────────────────────────────────────────────────────────────────
log "  superskills ready"
log "  ${#LINKED[@]} skills linked (Claude Code + OpenCode)"
log "  includes marketing-skills: SEO, content, pages, ads, channels, strategies"
log "  includes design-skills: UX, frontend engineering, animation, Swift/iOS, Vercel"
if [ -f "$KB_CONF" ] && [ -s "$KB_CONF" ]; then
  kb_count=$(grep -c '.' "$KB_CONF" 2>/dev/null || echo 0)
  log "  $kb_count knowledge base(s) configured"
fi
log ""
log "  To update: cd $SOURCE_DIR && git pull && ./setup"
log "  To add knowledge bases: edit ~/.superskills/knowledge.conf"
log ""
